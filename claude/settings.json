  "model": "claude-fable-5",
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/with-anthropic-key.sh python3 $HOME/.claude/hooks/auto_classify.py",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/retry_omitted_grep.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/session_rename_commit.sh",
            "if": "Bash(git commit*)",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/mark_failed_sync.sh",
            "if": "Bash(git *)",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/agent_spawned.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/mask_env_read.sh",
            "if": "Read(**/.env*)",
            "timeout": 5,
            "statusMessage": "Masking secret values in env file"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/mask_env_read.sh",
            "if": "Read(**/.envrc)",
            "timeout": 5,
            "statusMessage": "Masking secret values in envrc file"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/check_loop_bypass.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/network_audit.py",
            "timeout": 3,
            "statusMessage": "Auditing network intent"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/mask_env_read.sh",
            "if": "Bash(*.env*)",
            "timeout": 5,
            "statusMessage": "Masking secret values in env file"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block_email_send.sh",
            "if": "Bash(*gws*gmail*)",
            "timeout": 5,
            "statusMessage": "Checking for email send commands"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block_gws_delete.sh",
            "if": "Bash(*gws*)",
            "timeout": 5,
            "statusMessage": "Checking for GWS deletion commands"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/nudge_modern_tools.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/warn_dep_install.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/guard_post_rebase.sh",
            "if": "Bash(git commit*)",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/guard_settings_commit.sh",
            "if": "Bash(git *)",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/nudge_experiment_jobs.sh",
            "if": "Bash(*python*)",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/check_agent_depth.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/check_webfetch_domain.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "mcp__claude-in-chrome__tabs_context_mcp",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block_tab_group_creation.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "mcp__claude_ai_Gmail__gmail_create_draft",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/nudge_html_email.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/require_plan_approval.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/watchdog_stop.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/auto_commit.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/watchdog_start.sh",
            "timeout": 5,
            "async": true
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/fix_hook_permissions.sh",
            "timeout": 5,
            "async": true
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/detect_repo_trust.sh",
            "timeout": 3,
            "async": true
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/check_git_root.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/check_venv.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/pre_session_start.sh",
            "timeout": 10,
            "async": true
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/session_start_notes.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/show_auth_account.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/context_auto_apply.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/check_things_mcp.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/watchdog_mark.sh idle",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/nudge_remember.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/with-anthropic-key.sh $HOME/.claude/hooks/session_rename_auto.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/watchdog_mark.sh working",
            "timeout": 3
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": [
      ".venv",
      "node_modules",
      "target",
      ".git/lfs"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "claude-tools statusline || bash $HOME/.claude/statusline.sh",
    "padding": 1
  },
