# User configuration for git settings
# Copy this file to user.conf and customize with your own values
# Example: cp config/user.conf.example config/user.conf

# Git user configuration
GIT_USER_EMAIL="30549145+yulonglin@users.noreply.github.com"
GIT_USER_NAME="yulonglin"

# Username for non-root development user (used by install.sh --create-user)
DEV_USERNAME="yulong"

# Gist for bidirectional config sync (SSH config, authorized_keys, git identity).
# Create your own with: gh gist create ~/.ssh/config --desc "dotfiles sync"
# Unlisted, NOT encrypted — never put secrets (API keys, private keys) in it.
# Leave empty to disable gist sync.
GIST_SYNC_ID=""

# Note: If config/user.conf exists, deploy.sh will use these values.
# Otherwise, it will use the defaults specified above.
