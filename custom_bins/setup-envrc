#!/usr/bin/env bash
# shellcheck shell=bash
# Configure repo-scoped secret exports via .envrc.
# Usage:
#   setup-envrc                                  # interactive picker for the repo root
#   setup-envrc KEY1 KEY2                       # export secrets with matching env names
#   setup-envrc ENV_VAR=SECRET_NAME             # map a secret to a repo-local env var name
#   setup-envrc --telegram-secret SECRET_NAME   # materialize Telegram plugin token at Claude launch
#   setup-envrc --all                           # export every managed key
#   setup-envrc --list                          # show current repo .envrc bindings
#   setup-envrc --clean                         # remove repo .envrc
set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
DOT_DIR="${DOT_DIR:-$(cd "$SCRIPT_DIR/.." && pwd)}"
SECRETS_HELPER="$DOT_DIR/custom_bins/dotfiles-secrets"
# shellcheck source=/dev/null
source "$DOT_DIR/scripts/helpers/dotfiles_secrets.sh"
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
ENVRC="$REPO_ROOT/.envrc"
KEY_PATTERN='API.?KEY|TOKEN|SECRET|PASSWORD|CREDENTIAL'
TELEGRAM_SECRET_PATTERN='TELEGRAM|BOT.?TOKEN'
SECRETS_CACHE=""

die() {
    echo "Error: $*" >&2
    exit 1
}

usage() {
    cat <<'EOF'
Usage:
  setup-envrc                         Interactive picker (fzf)
  setup-envrc KEY1 KEY2               Export secrets with matching env names
  setup-envrc ENV_VAR=SECRET_NAME     Map a secret to a custom env var name
  setup-envrc --telegram-secret NAME  Materialize Telegram token at Claude launch
  setup-envrc --all                   Export every managed key
  setup-envrc --list                  Show current repo .envrc bindings
  setup-envrc --clean                 Remove .envrc and nested .env files

BWS key naming convention:
  ENV_VAR_NAME - description          The part before " - " becomes the env var.
  Examples:
    ANTHROPIC_API_KEY - mats        → exports as ANTHROPIC_API_KEY
    OPENAI_API_KEY - research       → exports as OPENAI_API_KEY
    HF_TOKEN                        → exports as HF_TOKEN (no description)
EOF
}

safe_remove() {
    local path="$1"
    if command -v trash >/dev/null 2>&1; then
        trash "$path"
    else
        rm "$path"
    fi
}

load_secrets_cache() {
    [[ -n "$SECRETS_CACHE" ]] && return 0
    [[ -x "$SECRETS_HELPER" ]] || die "$SECRETS_HELPER not found"
    SECRETS_CACHE=$("$SECRETS_HELPER" dotenv)
}

normalize_value() {
    local value="$1"
    value="${value%$'\r'}"

    if [[ "$value" =~ ^\"(.*)\"$ ]]; then
        value="${BASH_REMATCH[1]}"
        # Process \\ first via sentinel to prevent \\n being misread as \n
        local sentinel=$'\x01'
        value="${value//\\\\/$sentinel}"
        value="${value//\\n/$'\n'}"
        value="${value//\\r/$'\r'}"
        value="${value//\\t/$'\t'}"
        value="${value//\\\"/\"}"
        value="${value//$sentinel/\\}"
    elif [[ "$value" =~ ^\'(.*)\'$ ]]; then
        value="${BASH_REMATCH[1]}"
        value="${value//\\\'/\'}"
        value="${value//\\\\/\\}"
    fi

    printf '%s' "$value"
}

content_has_key() {
    local content="$1"
    local key="$2"

    [[ -n "$content" ]] || return 1

    printf '%s\n' "$content" | awk -v key="$key" '
        /^[[:space:]]*#/ || /^[[:space:]]*$/ { next }
        {
            line = $0
            sub(/\r$/, "", line)
            sub(/^[[:space:]]*export[[:space:]]+/, "", line)
            if (line ~ ("^" key "=")) {
                found = 1
                exit
            }
        }
        END { exit(found ? 0 : 1) }
    '
}

get_value_from_content() {
    local content="$1"
    local key="$2"
    local raw_value

    raw_value=$(printf '%s\n' "$content" | awk -v key="$key" '
        /^[[:space:]]*#/ || /^[[:space:]]*$/ { next }
        {
            line = $0
            sub(/\r$/, "", line)
            sub(/^[[:space:]]*export[[:space:]]+/, "", line)
            if (line ~ ("^" key "=")) {
                print substr(line, length(key) + 2)
                exit
            }
        }
    ')

    normalize_value "$raw_value"
}

list_sensitive_keys() {
    load_secrets_cache
    local keys
    keys=$(printf '%s\n' "$SECRETS_CACHE" \
        | sed -n 's/^[[:space:]]*\([A-Za-z_][A-Za-z0-9_-]*\)=.*/\1/p')
    # BWS entries are all secrets; only filter SOPS dotenv (which may have non-secret config)
    if [[ "$(dotfiles_secrets_backend)" != "bws" ]]; then
        keys=$(printf '%s\n' "$keys" | grep -iE "$KEY_PATTERN")
    fi
    printf '%s\n' "$keys" | sort -u || true
}

validate_env_name() {
    local name="$1"
    [[ "$name" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || die "Invalid environment variable name: $name"
}


binding_env_key() {
    local binding="$1"
    if [[ "$binding" == *=* ]]; then
        printf '%s\n' "${binding%%=*}"
    else
        printf '%s\n' "$binding"
    fi
}

binding_secret_key() {
    local binding="$1"
    if [[ "$binding" == *=* ]]; then
        printf '%s\n' "${binding#*=}"
    else
        printf '%s\n' "$binding"
    fi
}

canonicalize_binding() {
    local binding="$1"
    local env_key secret_key

    env_key=$(binding_env_key "$binding")
    secret_key=$(binding_secret_key "$binding")

    validate_env_name "$env_key"
    validate_env_name "$secret_key"

    if [[ "$env_key" == "$secret_key" ]]; then
        printf '%s\n' "$env_key"
    else
        printf '%s=%s\n' "$env_key" "$secret_key"
    fi
}

binding_display() {
    local binding="$1"
    local env_key secret_key

    env_key=$(binding_env_key "$binding")
    secret_key=$(binding_secret_key "$binding")

    if [[ "$env_key" == "$secret_key" ]]; then
        printf 'export %s\n' "$env_key"
    else
        printf 'export %s <- %s\n' "$env_key" "$secret_key"
    fi
}

normalize_export_bindings() {
    local binding canonical env_key
    local normalized=()
    local seen_envs=""

    for binding in "$@"; do
        [[ -n "$binding" ]] || continue
        canonical=$(canonicalize_binding "$binding")
        env_key=$(binding_env_key "$canonical")

        if has_line "$env_key" "$seen_envs"; then
            die "Duplicate export binding for $env_key"
        fi

        normalized+=("$canonical")
        seen_envs+="$env_key"$'\n'
    done

    if [[ ${#normalized[@]} -gt 0 ]]; then
        printf '%s\n' "${normalized[@]}"
    fi
}

current_envrc_export_bindings() {
    [[ -f "$ENVRC" ]] || return 0

    if grep -q '^# setup-envrc exports:' "$ENVRC"; then
        sed -n 's/^# setup-envrc exports:[[:space:]]*//p' "$ENVRC" | tr ' ' '\n' | sed '/^$/d'
        return 0
    fi

    if grep -q '^# setup-envrc:' "$ENVRC"; then
        sed -n 's/^# setup-envrc:[[:space:]]*//p' "$ENVRC" | tr ' ' '\n' | sed '/^$/d'
        return 0
    fi

    if grep -q '^# env-context:' "$ENVRC"; then
        sed -n 's/^# env-context:[[:space:]]*//p' "$ENVRC" | tr ' ' '\n' | sed '/^$/d'
        return 0
    fi

    sed -n 's/^export[[:space:]]\+\([A-Za-z_][A-Za-z0-9_]*\)=.*/\1/p' "$ENVRC"
}

current_envrc_telegram_secret() {
    [[ -f "$ENVRC" ]] || return 0
    sed -n 's/^# setup-envrc telegram-secret:[[:space:]]*//p' "$ENVRC" | head -n 1
}

has_line() {
    local needle="$1"
    local haystack="$2"

    [[ -n "$haystack" ]] || return 1
    printf '%s\n' "$haystack" | grep -Fxq "$needle"
}

binding_for_secret() {
    local target_secret="$1"
    shift
    local binding

    for binding in "$@"; do
        [[ "$(binding_secret_key "$binding")" == "$target_secret" ]] || continue
        printf '%s\n' "$binding"
        return 0
    done

    return 1
}

bound_secret_for_env_key() {
    local env_key="$1"
    local telegram_secret="$2"
    local available_keys="$3"
    shift 3
    local binding

    for binding in "$@"; do
        [[ "$(binding_env_key "$binding")" == "$env_key" ]] || continue
        printf '%s\n' "$(binding_secret_key "$binding")"
        return 0
    done

    if [[ "$env_key" == "TELEGRAM_BOT_TOKEN" && -n "$telegram_secret" ]]; then
        printf '%s\n' "$telegram_secret"
        return 0
    fi

    if has_line "$env_key" "$available_keys"; then
        printf '%s\n' "$env_key"
        return 0
    fi

    return 1
}

repo_uses_telegram_plugin() {
    [[ -d "$REPO_ROOT/.claude/channels/telegram" ]] && return 0
    [[ -f "$REPO_ROOT/.claude/settings.json" ]] || return 1
    grep -Eq '"telegram@claude-plugins-official"[[:space:]]*:[[:space:]]*true' "$REPO_ROOT/.claude/settings.json"
}

telegram_secret_candidates() {
    list_sensitive_keys | grep -iE "$TELEGRAM_SECRET_PATTERN" || true
}

write_envrc() {
    local telegram_secret="$1"
    shift
    local export_bindings=("$@")
    local helper_bin="$DOT_DIR/custom_bins/dotfiles-secrets"
    local secrets_enc
    local sops_config
    local binding env_key secret_key
    local required_secrets=()
    local final_env_names=""

    secrets_enc=$(dotfiles_secrets_enc)
    sops_config=$(dotfiles_secrets_sops_config)

    for binding in "${export_bindings[@]}"; do
        env_key=$(binding_env_key "$binding")
        secret_key=$(binding_secret_key "$binding")
        final_env_names+="$env_key"$'\n'
        if ! has_line "$secret_key" "$(printf '%s\n' "${required_secrets[@]}")"; then
            required_secrets+=("$secret_key")
        fi
    done

    {
        echo "# Auto-generated by setup-envrc -- re-run to modify, --clean to remove"
        printf '# setup-envrc exports:'
        for binding in "${export_bindings[@]}"; do
            printf ' %s' "$binding"
        done
        echo ""
        if [[ -n "$telegram_secret" ]]; then
            printf '# setup-envrc telegram-secret: %s\n' "$telegram_secret"
        fi
        printf 'watch_file %q\n' "$helper_bin"
        # Watch the secrets cache file so direnv reloads when background refresh lands
        local _cache_path
        _cache_path=$("$helper_bin" cache-path 2>/dev/null)
        [[ -n "$_cache_path" ]] && printf 'watch_file %q\n' "$_cache_path"
        # Watch ALL backend files so direnv detects backend switches (SOPS→BWS or vice versa)
        local _paths_output
        _paths_output=$("$helper_bin" paths 2>/dev/null)
        local _bws_token
        _bws_token=$(printf '%s\n' "$_paths_output" | sed -n 's/^BWS_TOKEN_FILE=//p')
        [[ -n "$_bws_token" ]] && printf 'watch_file %q\n' "$_bws_token"
        printf 'watch_file %q\n' "$secrets_enc"
        printf 'watch_file %q\n' "$sops_config"
        # Pin backend override if explicitly set at generation time
        if [[ -n "${DOTFILES_SECRETS_BACKEND:-}" ]]; then
            printf 'export DOTFILES_SECRETS_BACKEND=%q\n' "$DOTFILES_SECRETS_BACKEND"
        fi
        printf 'DOTFILES_SECRETS_BIN=%q\n' "$helper_bin"

        if [[ ${#required_secrets[@]} -gt 0 ]]; then
            # shellcheck disable=SC2016
            printf 'eval "$("$DOTFILES_SECRETS_BIN" shell'
            for secret_key in "${required_secrets[@]}"; do
                printf ' %q' "$secret_key"
            done
            echo ')"'

            for binding in "${export_bindings[@]}"; do
                env_key=$(binding_env_key "$binding")
                secret_key=$(binding_secret_key "$binding")
                if [[ "$env_key" != "$secret_key" ]]; then
                    printf 'export %s="$%s"\n' "$env_key" "$secret_key"
                fi
            done

            for secret_key in "${required_secrets[@]}"; do
                if ! has_line "$secret_key" "$final_env_names"; then
                    printf 'unset %s\n' "$secret_key"
                fi
            done
        fi

        echo 'unset DOTFILES_SECRETS_BIN'

        if [[ -n "$telegram_secret" ]]; then
            printf 'export TELEGRAM_STATE_DIR=%q\n' "$REPO_ROOT/.claude/channels/telegram"
            printf 'export DOTFILES_TELEGRAM_BOT_SECRET=%q\n' "$telegram_secret"
        else
            echo 'unset TELEGRAM_STATE_DIR'
            echo 'unset DOTFILES_TELEGRAM_BOT_SECRET'
        fi
    } > "$ENVRC"
}

ensure_envrc_gitignored() {
    local gitignore="$REPO_ROOT/.gitignore"

    if ! { [[ -f "$gitignore" ]] && grep -q '^\.envrc$' "$gitignore"; }; then
        echo ".envrc" >> "$gitignore"
        echo "Added .envrc to $gitignore"
    fi
}

attempt_direnv_allow() {
    local allow_err=""

    if ! command -v direnv >/dev/null 2>&1; then
        echo "direnv not found; install it to auto-load .envrc" >&2
        return 0
    fi

    if allow_err=$(cd "$REPO_ROOT" && direnv allow . 2>&1); then
        return 0
    fi

    if printf '%s' "$allow_err" | grep -Eqi 'read-only file system|operation not permitted|permission denied'; then
        echo "direnv allow could not update its allowlist automatically in this environment." >&2
    else
        echo "direnv allow failed for $REPO_ROOT." >&2
    fi
    echo "Run manually: cd $REPO_ROOT && direnv allow ." >&2
}

harden_repo_secret_permissions() {
    dotfiles_secrets_harden_permissions
    project_secret_harden_permissions "$REPO_ROOT"

    if [[ -n "${1:-}" ]]; then
        telegram_state_harden_permissions "$1"
    fi
}

find_env_files() {
    find "$REPO_ROOT" -maxdepth 3 \
        \( \
            -path "$REPO_ROOT/.git" -o \
            -path "$REPO_ROOT/.direnv" -o \
            -path "$REPO_ROOT/node_modules" -o \
            -path "$REPO_ROOT/.venv" -o \
            -path "$REPO_ROOT/venv" -o \
            -path "$REPO_ROOT/build" -o \
            -path "$REPO_ROOT/dist" -o \
            -path "$REPO_ROOT/.claude/channels" -o \
            -path "$REPO_ROOT/claude/plugins/cache" -o \
            -path "$REPO_ROOT/claude/plugins/plugins.bak" -o \
            -path "$REPO_ROOT/codex/.tmp" \
        \) -prune -o \
        \( -type f -o -type l \) -name '.env' -print | sort
}

list_file_keys() {
    local env_file="$1"

    awk '
        /^[[:space:]]*#/ || /^[[:space:]]*$/ { next }
        {
            line = $0
            sub(/\r$/, "", line)
            sub(/^[[:space:]]*export[[:space:]]+/, "", line)
            if (line ~ /^[A-Za-z_][A-Za-z0-9_]*=/) {
                sub(/=.*/, "", line)
                print line
            }
        }
    ' "$env_file" | sort -u
}

build_env_file_summary() {
    local env_file="$1"
    local telegram_secret="$2"
    shift 2
    local export_bindings=("$@")
    local rel_path managed_same managed_diff unmanaged total_keys key secret_key
    local file_content available_keys file_keys

    rel_path="${env_file#"$REPO_ROOT"/}"
    [[ "$rel_path" == "$env_file" ]] && rel_path=$(basename "$env_file")
    file_content=$(cat "$env_file")
    available_keys=$(list_sensitive_keys)
    file_keys=$(list_file_keys "$env_file")
    managed_same=0
    managed_diff=0
    unmanaged=0
    total_keys=0

    while IFS= read -r key; do
        [[ -n "$key" ]] || continue
        total_keys=$((total_keys + 1))

        if secret_key=$(bound_secret_for_env_key "$key" "$telegram_secret" "$available_keys" "${export_bindings[@]}"); then
            if [[ "$(get_value_from_content "$file_content" "$key")" == "$(get_value_from_content "$SECRETS_CACHE" "$secret_key")" ]]; then
                managed_same=$((managed_same + 1))
            else
                managed_diff=$((managed_diff + 1))
            fi
        else
            unmanaged=$((unmanaged + 1))
        fi
    done <<< "$file_keys"

    printf '%s\t[same:%d] [diff:%d] [unmanaged:%d] [vars:%d]\n' \
        "$rel_path" "$managed_same" "$managed_diff" "$unmanaged" "$total_keys"
}

mask_value() {
    local value="$1"
    local len=${#value}

    if [[ $len -eq 0 ]]; then
        printf '%s' "(empty)"
    elif [[ $len -le 8 ]]; then
        printf '%s' "****"
    else
        printf '%s...%s' "${value:0:4}" "${value: -4}"
    fi
}

build_env_file_detail() {
    local env_file="$1"
    local telegram_secret="$2"
    shift 2
    local export_bindings=("$@")
    local key secret_key value masked status color file_content available_keys file_keys
    local green=$'\033[0;32m' yellow=$'\033[0;33m' red=$'\033[0;31m' dim=$'\033[2m' reset=$'\033[0m'
    local count_same=0 count_diff=0 count_unmanaged=0

    file_content=$(cat "$env_file")
    available_keys=$(list_sensitive_keys)
    file_keys=$(list_file_keys "$env_file")

    while IFS= read -r key; do
        [[ -n "$key" ]] || continue
        value=$(get_value_from_content "$file_content" "$key")
        masked=$(mask_value "$value")

        if secret_key=$(bound_secret_for_env_key "$key" "$telegram_secret" "$available_keys" "${export_bindings[@]}"); then
            if [[ "$value" == "$(get_value_from_content "$SECRETS_CACHE" "$secret_key")" ]]; then
                status="same"; color="$green"; count_same=$((count_same + 1))
            else
                status="diff"; color="$yellow"; count_diff=$((count_diff + 1))
            fi
        else
            status="unmanaged"; color="$red"; count_unmanaged=$((count_unmanaged + 1))
        fi

        printf '    %s%-10s%s %s=%s%s%s\n' "$color" "[$status]" "$reset" "$key" "$dim" "$masked" "$reset"
    done <<< "$file_keys"

    # Per-file safety verdict
    if [[ $count_unmanaged -eq 0 && $count_diff -eq 0 ]]; then
        printf '    %s✓ Safe to delete — all values match .envrc managed secrets%s\n' "$green" "$reset"
    elif [[ $count_unmanaged -eq 0 && $count_diff -gt 0 ]]; then
        printf '    %s⚠ Values differ from managed secrets — review before deleting%s\n' "$yellow" "$reset"
    else
        printf '    %s✗ Has unmanaged keys — not covered by .envrc, would be lost%s\n' "$red" "$reset"
    fi
}

print_env_file_summary() {
    local telegram_secret="$1"
    shift
    local export_bindings=("$@")
    local found=0 env_file

    local green=$'\033[0;32m' yellow=$'\033[0;33m' red=$'\033[0;31m' reset=$'\033[0m'

    while IFS= read -r env_file; do
        [[ -n "$env_file" ]] || continue
        if [[ "$found" -eq 0 ]]; then
            echo ""
            echo "Detected .env files in this repo:"
            printf '  %s[same]%s = matches .envrc secret  %s[diff]%s = value differs  %s[unmanaged]%s = not in .envrc\n' \
                "$green" "$reset" "$yellow" "$reset" "$red" "$reset"
        fi
        build_env_file_summary "$env_file" "$telegram_secret" "${export_bindings[@]}"
        build_env_file_detail "$env_file" "$telegram_secret" "${export_bindings[@]}"
        found=1
    done < <(find_env_files)

    return "$found"
}

collect_unmanaged_keys() {
    local telegram_secret="$1"
    shift
    local export_bindings=("$@")
    local env_file key secret_key file_content available_keys file_keys value rel_path

    available_keys=$(list_sensitive_keys)

    while IFS= read -r env_file; do
        [[ -n "$env_file" ]] || continue
        file_content=$(cat "$env_file")
        file_keys=$(list_file_keys "$env_file")
        rel_path="${env_file#"$REPO_ROOT"/}"
        [[ "$rel_path" == "$env_file" ]] && rel_path=$(basename "$env_file")

        while IFS= read -r key; do
            [[ -n "$key" ]] || continue
            if ! bound_secret_for_env_key "$key" "$telegram_secret" "$available_keys" "${export_bindings[@]}" >/dev/null 2>&1; then
                value=$(get_value_from_content "$file_content" "$key")
                local masked
                masked=$(mask_value "$value")
                # NUL-terminated records, RS-separated fields (values may contain newlines)
                printf '%s\x1e%s\x1e%s\x1e%s\0' "$key" "$masked" "$value" "$rel_path"
            fi
        done <<< "$file_keys"
    done < <(find_env_files)
}

offer_env_import() {
    local telegram_secret="$1"
    shift
    local export_bindings=("$@")

    [[ -t 0 ]] || return 0
    [[ "$(dotfiles_secrets_backend)" == "bws" ]] || return 0
    command -v fzf >/dev/null 2>&1 || return 0

    local unmanaged_entries=()
    while IFS= read -r -d '' entry; do
        [[ -n "$entry" ]] || continue
        unmanaged_entries+=("$entry")
    done < <(collect_unmanaged_keys "$telegram_secret" "${export_bindings[@]}")

    [[ ${#unmanaged_entries[@]} -gt 0 ]] || return 0

    local menu_items=() RS=$'\x1e'
    for entry in "${unmanaged_entries[@]}"; do
        local key masked source_file
        IFS="$RS" read -r key masked _ source_file <<< "$entry"
        # Hidden field 3 carries source_file for disambiguation
        menu_items+=("$(printf '%s=%s\t(%s)\t%s' "$key" "$masked" "$source_file" "$source_file")")
    done

    local selections
    selections=$(printf '%s\n' "${menu_items[@]}" | fzf --multi \
        --prompt="Import unmanaged keys into BWS> " \
        --header="SPACE to toggle, ENTER to confirm. ESC to skip." \
        --bind 'space:toggle' \
        --delimiter=$'\t' \
        --with-nth=1,2) || return 0

    [[ -n "$selections" ]] || return 0

    # All display output goes to /dev/tty; only binding lines go to stdout (captured by caller)
    local tty=/dev/tty

    # Show existing BWS keys (full key names) for naming context
    local dim=$'\033[2m' bold=$'\033[1m' red=$'\033[0;31m' reset=$'\033[0m'
    echo "" >"$tty"
    printf '  %sExisting BWS keys:%s  %s(format: ENV_NAME - description)%s\n' \
        "$bold" "$reset" "$dim" "$reset" >"$tty"
    while IFS=$'\t' read -r _env bws_key _note; do
        [[ -n "$_env" ]] && printf '    %s%s%s\n' "$dim" "$bws_key" "$reset" >"$tty"
    done < <("$SECRETS_HELPER" keys-meta 2>/dev/null)
    echo "" >"$tty"

    local imported=0 new_bindings=()
    while IFS= read -r selected; do
        [[ -n "$selected" ]] || continue
        local sel_key="${selected%%=*}"
        # Extract source_file from hidden 3rd tab field for disambiguation
        local sel_source
        sel_source=$(printf '%s' "$selected" | cut -f3)

        for entry in "${unmanaged_entries[@]}"; do
            local entry_key entry_value entry_masked entry_source
            IFS="$RS" read -r entry_key entry_masked entry_value entry_source <<< "$entry"
            if [[ "$entry_key" == "$sel_key" && "$entry_source" == "$sel_source" ]]; then
                local import_key local_key

                printf '\n  ─── Importing: %s%s%s=%s%s%s ───\n' \
                    "$bold" "$sel_key" "$reset" "$dim" "$entry_masked" "$reset" >"$tty"

                # 1. BWS key name (accepts "NAME - description" convention)
                local bws_desc=""
                while true; do
                    printf '  BWS key name   [enter = %s]: ' "$sel_key" >"$tty"
                    read -r import_key <"$tty"
                    [[ -n "$import_key" ]] || import_key="$sel_key"
                    # Parse "ENV_NAME - description" → env name + bws description
                    if [[ "$import_key" == *" - "* ]]; then
                        bws_desc="${import_key#* - }"
                        import_key="${import_key%% - *}"
                    fi
                    [[ "$import_key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] && break
                    printf '  Invalid name: %s (must be [A-Za-z_][A-Za-z0-9_]*)\n' "$import_key" >"$tty"
                done

                # 2. Local env var name (how it appears in .envrc / your code)
                while true; do
                    printf '  Local env var  [enter = %s]: ' "$sel_key" >"$tty"
                    read -r local_key <"$tty"
                    [[ -n "$local_key" ]] || local_key="$sel_key"
                    [[ "$local_key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] && break
                    printf '  Invalid name: %s (must be [A-Za-z_][A-Za-z0-9_]*)\n' "$local_key" >"$tty"
                done

                # Summary before committing
                local bws_display="$import_key"
                [[ -n "$bws_desc" ]] && bws_display="$import_key - $bws_desc"
                printf '\n  %sBWS:%s      %s\n' "$bold" "$reset" "$bws_display" >"$tty"
                printf '  %sLocal:%s    %s\n' "$bold" "$reset" "$local_key" >"$tty"
                if [[ "$local_key" != "$import_key" ]]; then
                    printf '  %sMapping:%s  %s <- %s\n' "$bold" "$reset" "$local_key" "$import_key" >"$tty"
                fi
                echo "" >"$tty"

                local set_args=("$import_key" "$entry_value")
                [[ -n "$bws_desc" ]] && set_args+=(--note "$bws_desc")
                if "$SECRETS_HELPER" set "${set_args[@]}" >"$tty" 2>"$tty"; then
                    # Track new binding for .envrc rewrite
                    if [[ "$local_key" != "$import_key" ]]; then
                        new_bindings+=("$local_key=$import_key")
                    else
                        new_bindings+=("$import_key")
                    fi
                    imported=$((imported + 1))
                else
                    printf '  %sError: failed to import %s — skipping%s\n' "$red" "$import_key" "$reset" >"$tty"
                fi
                break
            fi
        done
    done <<< "$selections"

    if [[ $imported -gt 0 ]]; then
        printf 'Imported %d key(s) into BWS.\n' "$imported" >"$tty"
        # Output new bindings to stdout so caller can capture and rewrite .envrc
        printf '%s\n' "${new_bindings[@]}"
        # Invalidate in-memory cache so subsequent steps see the new keys
        SECRETS_CACHE=""
    fi
}

offer_env_cleanup() {
    local telegram_secret="$1"
    shift
    local export_bindings=("$@")

    [[ -t 0 ]] || return 0
    command -v fzf >/dev/null 2>&1 || return 0

    local env_file item rel_path summary default_select=() selections selected_items reply
    local menu_items=()

    while IFS= read -r env_file; do
        [[ -n "$env_file" ]] || continue
        summary=$(build_env_file_summary "$env_file" "$telegram_secret" "${export_bindings[@]}")
        menu_items+=("$summary")
        rel_path="${env_file#"$REPO_ROOT"/}"
        if [[ "$rel_path" == ".env" ]]; then
            default_select+=(--query ".env")
        fi
    done < <(find_env_files)

    [[ ${#menu_items[@]} -gt 0 ]] || return 0

    selections=$(printf '%s\n' "${menu_items[@]}" | fzf --multi \
        --prompt="Select .env files to delete> " \
        --header="SPACE to toggle, ENTER to confirm. Root .env files shown first." \
        --bind 'space:toggle' \
        --with-nth=1 \
        --preview="cat \"$REPO_ROOT/{1}\"" \
        --preview-window=right:50%:wrap \
        "${default_select[@]}") || return 0

    [[ -n "$selections" ]] || return 0

    echo ""
    echo "Selected for deletion:"
    while IFS= read -r selected_items; do
        [[ -n "$selected_items" ]] || continue
        echo "  ${selected_items%%$'\t'*}"
    done <<< "$selections"

    read -r -p "Delete selected .env file(s)? [y/N] " reply
    case "$reply" in
        [yY]|[yY][eE][sS])
            while IFS= read -r selected_items; do
                [[ -n "$selected_items" ]] || continue
                rel_path="${selected_items%%$'\t'*}"
                safe_remove "$REPO_ROOT/$rel_path"
                echo "Removed $rel_path"
            done <<< "$selections"
            ;;
    esac
}

prompt_for_telegram_secret() {
    local current_secret="$1"
    local candidates=()
    local items=("<none>")
    local selected secret
    local select_args=()

    while IFS= read -r secret; do
        [[ -n "$secret" ]] || continue
        candidates+=("$secret")
    done < <(telegram_secret_candidates)

    if [[ -n "$current_secret" ]] && ! has_line "$current_secret" "$(printf '%s\n' "${candidates[@]}")"; then
        items+=("$current_secret")
    fi

    items+=("${candidates[@]}")
    [[ ${#items[@]} -gt 1 ]] || return 0

    if [[ -n "$current_secret" ]]; then
        select_args=(--query "$current_secret")
    else
        select_args=(--query "<none>")
    fi

    selected=$(printf '%s\n' "${items[@]}" | fzf \
        --prompt="Telegram bot secret for $(basename "$REPO_ROOT")> " \
        --header="Select a repo-specific Telegram token to materialize into .claude/channels/telegram/.env at Claude launch" \
        "${select_args[@]}") || {
            printf '%s\n' "$current_secret"
            return 0
        }

    if [[ "$selected" == "<none>" ]]; then
        printf '\n'
    else
        printf '%s\n' "$selected"
    fi
}

show_current_bindings() {
    local export_bindings=()
    local telegram_secret binding

    if [[ ! -f "$ENVRC" ]]; then
        echo "No .envrc in $REPO_ROOT"
        return 0
    fi

    mapfile -t export_bindings < <(current_envrc_export_bindings)
    mapfile -t export_bindings < <(normalize_export_bindings "${export_bindings[@]}")
    telegram_secret=$(current_envrc_telegram_secret)

    echo "Current .envrc bindings for $REPO_ROOT:"
    if [[ ${#export_bindings[@]} -eq 0 && -z "$telegram_secret" ]]; then
        echo "  (none)"
        return 0
    fi

    for binding in "${export_bindings[@]}"; do
        echo "  $(binding_display "$binding")"
    done

    if [[ -n "$telegram_secret" ]]; then
        echo "  telegram-file TELEGRAM_BOT_TOKEN <- $telegram_secret"
    fi
}

if [[ $# -eq 0 ]]; then
    selected_export_bindings=()
    include_all=false
    telegram_secret=""
else
    selected_export_bindings=()
    include_all=false
    telegram_secret=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                usage
                exit 0
                ;;
            --list)
                show_current_bindings
                exit 0
                ;;
            --clean)
                if [[ -f "$ENVRC" ]]; then
                    safe_remove "$ENVRC"
                    echo "Removed $ENVRC"
                else
                    echo "No .envrc to remove in $REPO_ROOT"
                fi
                exit 0
                ;;
            --all)
                include_all=true
                shift
                ;;
            --telegram-secret)
                [[ $# -ge 2 ]] || die "--telegram-secret requires SECRET_NAME"
                validate_env_name "$2"
                telegram_secret="$2"
                shift 2
                ;;
            *)
                selected_export_bindings+=("$1")
                shift
                ;;
        esac
    done
fi

if [[ "$include_all" == true ]]; then
    while IFS= read -r key; do
        [[ -n "$key" ]] && selected_export_bindings+=("$key")
    done < <(list_sensitive_keys)
fi

if [[ ${#selected_export_bindings[@]} -eq 0 && "$include_all" == false && -z "$telegram_secret" ]]; then
    command -v fzf >/dev/null 2>&1 || die "fzf required. Use: setup-envrc KEY1 KEY2 or ENV=SECRET"

    load_secrets_cache
    mapfile -t current_export_bindings < <(current_envrc_export_bindings)
    mapfile -t current_export_bindings < <(normalize_export_bindings "${current_export_bindings[@]}")
    current_telegram_secret=$(current_envrc_telegram_secret)
    menu_items=()

    # Load metadata (env_name\tbws_key\tnote) for rich display
    declare -A meta_bws_key meta_note
    while IFS=$'\t' read -r m_env m_bws m_note; do
        [[ -n "$m_env" ]] || continue
        meta_bws_key["$m_env"]="$m_bws"
        meta_note["$m_env"]="$m_note"
    done < <("$SECRETS_HELPER" keys-meta 2>/dev/null)

    preselect_positions=()
    item_pos=0

    while IFS= read -r key; do
        [[ -n "$key" ]] || continue
        item_pos=$((item_pos + 1))
        # Build display: "ENV_NAME  (bws: original-key)  note text  [envrc]"
        item="$key"
        bws_key="${meta_bws_key[$key]:-}"
        note="${meta_note[$key]:-}"

        # Show BWS key if it differs from env name
        if [[ -n "$bws_key" && "$bws_key" != "$key" ]]; then
            item+=$'\t'"(bws: $bws_key)"
        fi
        if [[ -n "$note" ]]; then
            item+=$'\t'"$note"
        fi

        existing_binding=$(binding_for_secret "$key" "${current_export_bindings[@]}" || true)
        if [[ -n "$existing_binding" ]]; then
            if [[ "$(binding_env_key "$existing_binding")" == "$key" ]]; then
                item+=$'\t'"[envrc]"
            else
                item+=$'\t'"[envrc->$(binding_env_key "$existing_binding")]"
            fi
            preselect_positions+=("$item_pos")
        fi

        menu_items+=("$item")
    done < <(list_sensitive_keys)

    if [[ ${#menu_items[@]} -eq 0 ]]; then
        die "No secrets found in $(dotfiles_secrets_backend) backend. Add secrets first."
    fi

    # Build fzf --bind load action to pre-select [envrc] items
    fzf_preselect_args=()
    if [[ ${#preselect_positions[@]} -gt 0 ]]; then
        bind_actions=""
        for pos in "${preselect_positions[@]}"; do
            bind_actions+="pos($pos)+select+"
        done
        bind_actions+="pos(1)"  # return cursor to top
        fzf_preselect_args=(--sync --bind "load:${bind_actions}")
    fi

    # Dump secrets + metadata to temp files for fzf preview
    preview_dotenv=$(mktemp "${TMPDIR:-/tmp}/setup-envrc.XXXXXX")
    preview_meta=$(mktemp "${TMPDIR:-/tmp}/setup-envrc.XXXXXX")
    # Append to existing EXIT trap rather than replacing it
    # shellcheck disable=SC2064
    _existing_trap=$(trap -p EXIT | sed "s/^trap -- '//;s/' EXIT$//")
    trap "${_existing_trap:+$_existing_trap; }rm -f '$preview_dotenv' '$preview_meta'" EXIT
    printf '%s\n' "$SECRETS_CACHE" > "$preview_dotenv"
    "$SECRETS_HELPER" keys-meta 2>/dev/null > "$preview_meta"

    selected=$(printf '%s\n' "${menu_items[@]}" | fzf --multi \
        --prompt="Select secrets for $(basename "$REPO_ROOT")> " \
        --header="SPACE to toggle, ENTER to confirm. Items tagged [envrc] are already configured." \
        --bind 'space:toggle' \
        --delimiter=$'\t' \
        --preview="key={1}; key=\${key//[^A-Za-z0-9_]/}; echo '--- Note ---'; awk -F'\t' -v k=\"\$key\" '\$1==k{print \$3}' '$preview_meta'; echo; echo '--- Value ---'; grep \"^\$key=\" '$preview_dotenv' | sed 's/^[^=]*=//'" \
        --preview-window=right:40%:wrap \
        "${fzf_preselect_args[@]}") || exit 0

    while IFS= read -r item; do
        [[ -n "$item" ]] || continue
        secret_name="${item%%$'\t'*}"
        existing_binding=$(binding_for_secret "$secret_name" "${current_export_bindings[@]}" || true)
        if [[ -n "$existing_binding" ]]; then
            selected_export_bindings+=("$existing_binding")
        else
            # Offer rename for newly selected secrets
            printf 'Local name for %s? (enter to keep): ' "$secret_name" >/dev/tty
            local_name=""
            read -r local_name </dev/tty
            if [[ -n "$local_name" && "$local_name" != "$secret_name" ]]; then
                selected_export_bindings+=("$local_name=$secret_name")
            else
                selected_export_bindings+=("$secret_name")
            fi
        fi
    done <<< "$selected"

    if repo_uses_telegram_plugin || [[ -n "$current_telegram_secret" ]]; then
        telegram_secret=$(prompt_for_telegram_secret "$current_telegram_secret")
    fi
fi

mapfile -t selected_export_bindings < <(normalize_export_bindings "${selected_export_bindings[@]}")

if [[ -n "$telegram_secret" ]]; then
    validate_env_name "$telegram_secret"
fi

if [[ ${#selected_export_bindings[@]} -eq 0 && -z "$telegram_secret" ]]; then
    if [[ -f "$ENVRC" ]]; then
        safe_remove "$ENVRC"
        echo "No bindings selected; removed $ENVRC"
    else
        echo "No bindings selected; no .envrc written"
    fi
    exit 0
fi

write_envrc "$telegram_secret" "${selected_export_bindings[@]}"
ensure_envrc_gitignored

attempt_direnv_allow

telegram_state_dir=""
if [[ -n "$telegram_secret" || -d "$REPO_ROOT/.claude/channels/telegram" ]]; then
    telegram_state_dir="$REPO_ROOT/.claude/channels/telegram"
fi
harden_repo_secret_permissions "$telegram_state_dir"

load_secrets_cache
print_env_file_summary "$telegram_secret" "${selected_export_bindings[@]}" || true

# Import unmanaged .env keys into BWS; capture new bindings
new_import_bindings=()
while IFS= read -r nb; do
    [[ -n "$nb" ]] && new_import_bindings+=("$nb")
done < <(offer_env_import "$telegram_secret" "${selected_export_bindings[@]}")

# If imports added new bindings, rewrite .envrc
if [[ ${#new_import_bindings[@]} -gt 0 ]]; then
    selected_export_bindings+=("${new_import_bindings[@]}")
    mapfile -t selected_export_bindings < <(normalize_export_bindings "${selected_export_bindings[@]}")
    write_envrc "$telegram_secret" "${selected_export_bindings[@]}"
    attempt_direnv_allow
    echo "Updated .envrc with ${#new_import_bindings[@]} imported binding(s)."
    # Reload cache and re-display
    SECRETS_CACHE=""
    load_secrets_cache
    print_env_file_summary "$telegram_secret" "${selected_export_bindings[@]}" || true
fi

offer_env_cleanup "$telegram_secret" "${selected_export_bindings[@]}"
echo ""
echo "${#selected_export_bindings[@]} export binding(s) scoped to $(basename "$REPO_ROOT")."
if [[ -n "$telegram_secret" ]]; then
    echo "Telegram plugin token will be materialized from $telegram_secret at Claude launch."
fi
