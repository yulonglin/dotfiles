#!/usr/bin/env bash

# Machine Name Script
#
# Outputs the machine name for display, used by:
# - config/p10k.zsh (prompt_remote_host)
# - claude/statusline.sh (machine info display)
#
# Output format: "EMOJI NAME" (e.g., "🚀 hetzner-1")
# Outputs nothing if machine is not registered and not in SSH session.
# Each machine gets a unique emoji based on its name hash.
#
# Environment variables:
# - SERVER_NAME: Override the machine name entirely
# - MACHINE_EMOJI: Override the emoji (otherwise auto-assigned per machine)
#
# Priority for name resolution:
# 1. $SERVER_NAME env var
# 2. Machine registry (config/machines.conf, matched by machine-id)
# 3. SSH config alias matching public IP (SSH sessions only)
# 4. Abbreviated hostname (SSH sessions only)
#
# Uses cached public IPs (~/.cache/public_ip_v4 and v6, 1 hour TTL) to avoid slow network calls.

# Locate dotfiles repo (follow symlinks from custom_bins)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")" && pwd)"
DOT_DIR="${SCRIPT_DIR%/custom_bins}"
REGISTRY="${DOT_DIR}/config/machines.conf"

hostname="${HOST:-$(hostname -s)}"
short_name=""
registry_emoji=""

# Get machine ID (cross-platform)
get_machine_id() {
  if [[ -f /etc/machine-id ]]; then
    cat /etc/machine-id
  elif command -v ioreg >/dev/null 2>&1; then
    ioreg -rd1 -c IOPlatformExpertDevice 2>/dev/null | awk -F'"' '/IOPlatformUUID/{print $4}' | tr '[:upper:]' '[:lower:]'
  fi
}

# Option 1: Use SERVER_NAME env var if set
if [[ -n "${SERVER_NAME:-}" ]]; then
  short_name="$SERVER_NAME"

# Option 2: Check machine registry
elif [[ -f "$REGISTRY" ]]; then
  machine_id=$(get_machine_id)
  if [[ -n "$machine_id" ]]; then
    registry_entry=$(grep "^${machine_id}|" "$REGISTRY" 2>/dev/null | head -1)
    if [[ -n "$registry_entry" ]]; then
      short_name=$(echo "$registry_entry" | cut -d'|' -f2)
      registry_emoji=$(echo "$registry_entry" | cut -d'|' -f3)
    fi
  fi
fi

# Options 3 & 4: SSH-only fallbacks (IP matching + hostname)
if [[ -z "$short_name" ]]; then
  # Not registered — only show name in SSH sessions
  [[ -z "${SSH_CONNECTION:-}" ]] && exit 0

  # Option 3: Parse SSH config to find alias matching public IP
  if [[ -f ~/.ssh/config ]]; then
    cache_dir="${HOME}/.cache"
    mkdir -p "$cache_dir"
    current_time=$(date +%s)

    # Helper: get cached IP if fresh (< 1 hour old)
    get_cached_ip() {
      local cache_file="$1"
      [[ ! -f "$cache_file" ]] && return 1
      local file_mtime
      if stat -c %Y "$cache_file" >/dev/null 2>&1; then
        file_mtime=$(stat -c %Y "$cache_file")
      else
        file_mtime=$(stat -f %m "$cache_file" 2>/dev/null || echo 0)
      fi
      local age=$((current_time - file_mtime))
      if [[ "$age" -lt 3600 ]]; then
        cat "$cache_file" 2>/dev/null
        return 0
      fi
      return 1
    }

    # Helper: match IP against SSH config HostName entries
    match_ssh_config() {
      local ip="$1"
      [[ -z "$ip" ]] && return
      awk -v target="$ip" '
        /^Host / {
          h = $2
          if (h ~ /^\*/) { host = ""; next }
          gsub(/[*?]+$/, "", h)
          host = h
        }
        /^[[:space:]]*HostName / { if ($2 == target && host != "") print host }
      ' ~/.ssh/config | head -1
    }

    # Get IPv4 (cached or fresh)
    ipv4=$(get_cached_ip "$cache_dir/public_ip_v4")
    if [[ -z "$ipv4" ]]; then
      ipv4=$(timeout 2 curl -4 -s ifconfig.me 2>/dev/null || timeout 2 curl -4 -s icanhazip.com 2>/dev/null)
      [[ -n "$ipv4" ]] && echo "$ipv4" > "$cache_dir/public_ip_v4"
    fi

    # Get IPv6 (cached or fresh)
    ipv6=$(get_cached_ip "$cache_dir/public_ip_v6")
    if [[ -z "$ipv6" ]]; then
      ipv6=$(timeout 2 curl -6 -s ifconfig.me 2>/dev/null || timeout 2 curl -6 -s icanhazip.com 2>/dev/null)
      [[ -n "$ipv6" ]] && echo "$ipv6" > "$cache_dir/public_ip_v6"
    fi

    # Try matching IPv4 first, then IPv6
    short_name=$(match_ssh_config "$ipv4")
    [[ -z "$short_name" ]] && short_name=$(match_ssh_config "$ipv6")
  fi

  # Option 4: Fallback — abbreviate long hostnames
  if [[ -z "$short_name" ]]; then
    if (( ${#hostname} > 10 )); then
      short_name="${hostname:0:6}.."
    else
      short_name="$hostname"
    fi
  fi
fi

# Select emoji: explicit override > registry > hash-based
if [[ -n "${MACHINE_EMOJI:-}" ]]; then
  icon="$MACHINE_EMOJI"
elif [[ -n "$registry_emoji" ]]; then
  icon="$registry_emoji"
else
  local_emojis=(
    "🚀" "💻" "🖥️" "⚡" "🔥" "🌟" "🎯" "🧠" "🛸" "🌊" "🎨" "🔮"
    "🦊" "🐙" "🦅" "🐋" "🐺" "🦈" "🦉" "🐝"
    "🌵" "🍄" "🌶️" "🌻" "🍀" "🌴"
    "⛏️" "🔧" "🧲" "💎" "🗡️" "🛡️"
  )
  if command -v md5sum >/dev/null 2>&1; then
    hash_val=$(echo -n "$short_name" | md5sum | cut -c1-8)
  elif command -v md5 >/dev/null 2>&1; then
    hash_val=$(echo -n "$short_name" | md5 | cut -c1-8)
  else
    hash_val="0"
  fi
  idx=$(( 16#$hash_val % ${#local_emojis[@]} ))
  icon="${local_emojis[$idx]}"
fi

echo "$icon $short_name"
