#!/usr/bin/env bash
# shellcheck shell=bash
# Access the private dotfiles secrets store.
# Usage:
#   dotfiles-secrets keys
#   dotfiles-secrets dotenv
#   dotfiles-secrets shell KEY1 [KEY2 ...]
#   dotfiles-secrets shell --all
#   dotfiles-secrets paths
#   dotfiles-secrets fix-perms
#   dotfiles-secrets set KEY [VALUE] [--note DESC]
#   dotfiles-secrets rm [--yes] KEY
#   dotfiles-secrets list-full
#   dotfiles-secrets write-telegram-env SECRET_NAME STATE_DIR
set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
DOT_DIR="${DOT_DIR:-$(cd "$SCRIPT_DIR/.." && pwd)}"
# shellcheck source=/dev/null
source "$DOT_DIR/scripts/helpers/dotfiles_secrets.sh"

BACKEND=$(dotfiles_secrets_backend)
BWS_TOKEN_FILE=$(dotfiles_secrets_bws_token_file)

if [[ "$BACKEND" == "sops" ]]; then
    SECRETS_ENC=$(dotfiles_secrets_enc)
    SOPS_CONFIG=$(dotfiles_secrets_sops_config)
fi
KEY_PATTERN='API.?KEY|TOKEN|SECRET|PASSWORD|CREDENTIAL'
SECRETS_CACHE=""
BWS_META_CACHE=""  # Tab-separated: env_name\tbws_key\tnote

# ─── file-based cache ────────────────────────────────────────────────────────
# Caches parsed secrets locally so direnv doesn't block on network calls.
# TTL default: 1 hour. Override with DOTFILES_SECRETS_CACHE_TTL (seconds).
# Cache dir: ~/.cache/dotfiles-secrets/ (700), files (600).

CACHE_DIR="${HOME}/.cache/dotfiles-secrets"
CACHE_TTL="${DOTFILES_SECRETS_CACHE_TTL:-3600}"

cache_file() {
    printf '%s/secrets.%s.cache\n' "$CACHE_DIR" "$BACKEND"
}

cache_meta_file() {
    printf '%s/meta.%s.cache\n' "$CACHE_DIR" "$BACKEND"
}

cache_is_fresh() {
    local cf="$1"
    [[ -f "$cf" ]] || return 1
    local now file_mtime age
    now=$(date +%s)
    # macOS stat -f%m, Linux stat -c%Y
    if file_mtime=$(stat -f%m "$cf" 2>/dev/null) || file_mtime=$(stat -c%Y "$cf" 2>/dev/null); then
        age=$((now - file_mtime))
        [[ $age -lt $CACHE_TTL ]]
    else
        return 1
    fi
}

cache_write() {
    ( umask 077; mkdir -p "$CACHE_DIR" )
    local cf tmp
    cf=$(cache_file)
    tmp="${cf}.tmp.$$"
    ( umask 077; printf '%s' "$SECRETS_CACHE" > "$tmp" )
    mv -f "$tmp" "$cf"
    if [[ -n "$BWS_META_CACHE" ]]; then
        local mf mtmp
        mf=$(cache_meta_file)
        mtmp="${mf}.tmp.$$"
        ( umask 077; printf '%s' "$BWS_META_CACHE" > "$mtmp" )
        mv -f "$mtmp" "$mf"
    fi
}

cache_read() {
    local cf
    cf=$(cache_file)
    [[ -f "$cf" ]] || return 1
    SECRETS_CACHE=$(cat "$cf")
    [[ -n "$SECRETS_CACHE" ]] || return 1
    local mf
    mf=$(cache_meta_file)
    [[ -f "$mf" ]] && BWS_META_CACHE=$(cat "$mf")
    return 0
}

cache_clear() {
    rm -f "$CACHE_DIR"/secrets.*.cache "$CACHE_DIR"/meta.*.cache 2>/dev/null
}

die() {
    echo "Error: $*" >&2
    exit 1
}

require_sops() {
    command -v sops >/dev/null 2>&1 || die "sops is required"
    [[ -f "$SECRETS_ENC" ]] || die "$SECRETS_ENC not found"
    [[ -f "$SOPS_CONFIG" ]] || die "$SOPS_CONFIG not found"
}

normalize_value() {
    local value="$1"
    value="${value%$'\r'}"

    if [[ "$value" =~ ^\"(.*)\"$ ]]; then
        value="${BASH_REMATCH[1]}"
        # Process \\ first via sentinel to prevent \\n being misread as \n
        local sentinel=$'\x01'
        value="${value//\\\\/$sentinel}"
        value="${value//\\n/$'\n'}"
        value="${value//\\r/$'\r'}"
        value="${value//\\t/$'\t'}"
        value="${value//\\\"/\"}"
        value="${value//$sentinel/\\}"
    elif [[ "$value" =~ ^\'(.*)\'$ ]]; then
        value="${BASH_REMATCH[1]}"
        value="${value//\\\'/\'}"
        value="${value//\\\\/\\}"
    fi

    printf '%s' "$value"
}

load_secrets_cache() {
    [[ -n "$SECRETS_CACHE" ]] && return 0
    require_sops
    SECRETS_CACHE=$(sops --input-type dotenv --output-type dotenv -d --config "$SOPS_CONFIG" "$SECRETS_ENC")
}

# ─── bws backend ─────────────────────────────────────────────────────────────

require_bws() {
    command -v bws >/dev/null 2>&1 || die "bws not found. Run: install.sh or cargo install bws"
    if [[ -z "${BWS_ACCESS_TOKEN:-}" ]]; then
        [[ -f "$BWS_TOKEN_FILE" ]] || die "No BWS_ACCESS_TOKEN and $BWS_TOKEN_FILE not found. Run: secrets-init-bws"
        BWS_ACCESS_TOKEN=$(cat "$BWS_TOKEN_FILE")
        export BWS_ACCESS_TOKEN
    fi
}

load_secrets_cache_bws() {
    [[ -n "$SECRETS_CACHE" ]] && return 0
    require_bws
    local json bws_stderr
    bws_stderr=$(mktemp "${TMPDIR:-/tmp}/bws_stderr.XXXXXX")
    json=$(bws secret list 2>"$bws_stderr") || {
        local err
        err=$(cat "$bws_stderr")
        rm -f "$bws_stderr"
        die "bws secret list failed: $err"
    }
    rm -f "$bws_stderr"
    local parsed
    parsed=$(printf '%s\n' "$json" | python3 -c '
import json, sys, re

data = json.load(sys.stdin)
if not isinstance(data, list):
    print(f"Unexpected bws output: expected JSON array, got {type(data).__name__}", file=sys.stderr)
    sys.exit(1)

seen = {}
dotenv_lines = []
meta_lines = []

for s in data:
    if "key" not in s or "value" not in s:
        print(f"Unexpected bws secret format: missing key/value in {list(s.keys())}", file=sys.stderr)
        sys.exit(1)

    bws_key = s["key"]
    note = (s.get("note") or "").strip().replace("\t", " ").replace("\n", " ")

    # Convention: "ENV_VAR_NAME - description" → env var is part before " - "
    env_name = bws_key.split(" - ", 1)[0].strip() if " - " in bws_key else bws_key

    # Validate env_name is a valid shell identifier
    if not re.match(r"^[A-Za-z_][A-Za-z0-9_]*$", env_name):
        desc = bws_key.split(" - ", 1)[1].strip() if " - " in bws_key else ""
        print(f"WARNING: BWS key {bws_key!r} → env name {env_name!r} is not a valid shell identifier. "
              f"Rename to ENV_VAR_NAME - description format.", file=sys.stderr)
        continue

    if env_name in seen:
        print(f"WARNING: duplicate env name {env_name!r} from BWS keys {seen[env_name]!r} and {bws_key!r}", file=sys.stderr)
    seen[env_name] = bws_key

    v = s["value"]
    if any(c in v for c in (" ", "\n", "\r", "\t", "\"", "'\''", "#", "$", "`", "\\", "=")):
        v = "\"" + v.replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n").replace("\r", "\\r").replace("\t", "\\t") + "\""
    dotenv_lines.append(f"{env_name}={v}")
    meta_lines.append(f"{env_name}\t{bws_key}\t{note}")

# Output: dotenv block, then META_SEPARATOR, then metadata block
print("\n".join(dotenv_lines))
print("__BWS_META__")
print("\n".join(meta_lines))
') || die "Failed to parse bws output (is the bws CLI version compatible?)"

    SECRETS_CACHE="${parsed%%__BWS_META__*}"
    SECRETS_CACHE="${SECRETS_CACHE%$'\n'}"
    BWS_META_CACHE="${parsed#*__BWS_META__}"
    BWS_META_CACHE="${BWS_META_CACHE#$'\n'}"
}

# ─── backend dispatch ────────────────────────────────────────────────────────

load_secrets_from_backend() {
    case "$BACKEND" in
        bws)  load_secrets_cache_bws ;;
        sops) load_secrets_cache ;;
        none) die "No secrets backend available. Run: secrets-init-bws (recommended) or secrets-init (SOPS)" ;;
        *)    die "Unknown backend: $BACKEND. Set DOTFILES_SECRETS_BACKEND to 'bws' or 'sops'" ;;
    esac
}

load_secrets() {
    # Fast path: serve from file cache if fresh
    local cf
    cf=$(cache_file)
    if cache_is_fresh "$cf"; then
        cache_read && return 0
    fi

    # Cache exists but stale? Serve stale + refresh in background
    if cache_read; then
        # Skip background refresh if a recent attempt failed (5 min backoff)
        local fail_marker="$CACHE_DIR/.refresh_failed"
        if [[ -f "$fail_marker" ]]; then
            local now fm_mtime fm_age
            now=$(date +%s)
            if fm_mtime=$(stat -f%m "$fail_marker" 2>/dev/null) || fm_mtime=$(stat -c%Y "$fail_marker" 2>/dev/null); then
                fm_age=$((now - fm_mtime))
                [[ $fm_age -lt 300 ]] && return 0  # backoff: don't retry for 5 min
            fi
        fi
        # Background refresh: fetch from backend and update cache file
        # shellcheck disable=SC2030  # subshell vars are intentionally local
        (
            SECRETS_CACHE=""
            BWS_META_CACHE=""
            if load_secrets_from_backend 2>>"$CACHE_DIR/.refresh.log"; then
                cache_write
                rm -f "$fail_marker"
            else
                touch "$fail_marker"
            fi
        ) >>/dev/null 2>&1 &
        disown 2>/dev/null
        return 0
    fi

    # No cache at all: must block on first fetch
    load_secrets_from_backend
    cache_write
}

content_has_key() {
    local content="$1"
    local key="$2"

    [[ -n "$content" ]] || return 1

    printf '%s\n' "$content" | awk -v key="$key" '
        /^[[:space:]]*#/ || /^[[:space:]]*$/ { next }
        {
            line = $0
            sub(/\r$/, "", line)
            sub(/^[[:space:]]*export[[:space:]]+/, "", line)
            if (line ~ ("^" key "=")) {
                found = 1
                exit
            }
        }
        END { exit(found ? 0 : 1) }
    '
}

get_value_from_content() {
    local content="$1"
    local key="$2"
    local raw_value

    raw_value=$(printf '%s\n' "$content" | awk -v key="$key" '
        /^[[:space:]]*#/ || /^[[:space:]]*$/ { next }
        {
            line = $0
            sub(/\r$/, "", line)
            sub(/^[[:space:]]*export[[:space:]]+/, "", line)
            if (line ~ ("^" key "=")) {
                print substr(line, length(key) + 2)
                exit
            }
        }
    ')

    normalize_value "$raw_value"
}

list_sensitive_keys() {
    load_secrets
    local keys
    keys=$(printf '%s\n' "$SECRETS_CACHE" \
        | sed -n 's/^[[:space:]]*\([A-Za-z_][A-Za-z0-9_-]*\)=.*/\1/p')
    if [[ "$BACKEND" != "bws" ]]; then
        keys=$(printf '%s\n' "$keys" | grep -iE "$KEY_PATTERN")
    fi
    printf '%s\n' "$keys" | sort -u || true
}

print_shell_exports() {
    local key
    local selected_keys=("$@")

    load_secrets

    for key in "${selected_keys[@]}"; do
        if ! content_has_key "$SECRETS_CACHE" "$key"; then
            echo "dotfiles-secrets: $key not found in encrypted secrets" >&2
            continue
        fi
        printf 'export %s=%q\n' "$key" "$(get_value_from_content "$SECRETS_CACHE" "$key")"
    done
}

write_telegram_env() {
    local secret_name="$1"
    local state_dir="$2"
    local env_file tmp_file token desired_content

    load_secrets
    content_has_key "$SECRETS_CACHE" "$secret_name" || die "$secret_name not found in encrypted secrets"

    token=$(get_value_from_content "$SECRETS_CACHE" "$secret_name")
    env_file="$state_dir/.env"
    tmp_file="${env_file}.tmp.$$"
    desired_content=$(printf 'TELEGRAM_BOT_TOKEN=%s\n' "$token")

    mkdir -p "$state_dir"
    telegram_state_harden_permissions "$state_dir"

    if [[ -f "$env_file" ]] && [[ "$(cat "$env_file")"$'\n' == "$desired_content" ]]; then
        chmod 600 "$env_file"
        printf '%s\n' "$env_file"
        return 0
    fi

    printf '%s' "$desired_content" > "$tmp_file"
    chmod 600 "$tmp_file"
    mv "$tmp_file" "$env_file"
    telegram_state_harden_permissions "$state_dir"
    printf '%s\n' "$env_file"
}

# ─── bws write helpers ──────────────────────────────────────────────────────

bws_project_id() {
    require_bws
    bws project list 2>/dev/null | python3 -c '
import json, sys
data = json.load(sys.stdin)
if not data:
    print("No BWS projects found", file=sys.stderr)
    sys.exit(1)
print(data[0]["id"])
' || die "Failed to get BWS project ID"
}

bws_find_secret() {
    local target_env="$1"
    require_bws
    bws secret list 2>/dev/null | python3 -c '
import json, sys
target = sys.argv[1]
data = json.load(sys.stdin)
for s in data:
    key = s["key"]
    env_name = key.split(" - ", 1)[0].strip() if " - " in key else key
    if env_name == target:
        note = (s.get("note") or "").strip()
        sid = s["id"]
        # Only emit id, key, note — callers need id (cut -f1), not the value
        # Omitting value avoids multiline values breaking tab-delimited output
        print(f"{sid}\t{key}\t{note}")
        sys.exit(0)
sys.exit(1)
' "$target_env" || return 1
}

bws_list_full() {
    require_bws
    bws secret list 2>/dev/null | python3 -c '
import json, sys, re
data = json.load(sys.stdin)
for s in data:
    key = s["key"]
    env_name = key.split(" - ", 1)[0].strip() if " - " in key else key
    if not re.match(r"^[A-Za-z_][A-Za-z0-9_]*$", env_name):
        continue
    note = (s.get("note") or "").strip().replace("\t", " ")
    val = s["value"]
    preview = val[:20] + "..." if len(val) > 20 else val
    sid = s["id"]
    print(f"{sid}\t{env_name}\t{key}\t{preview}\t{note}")
' || die "Failed to list BWS secrets"
}

bws_upsert() {
    local env_name="$1" value="$2" desc="${3:-}"
    local found secret_id project_id bws_key
    if found=$(bws_find_secret "$env_name" 2>/dev/null); then
        secret_id=$(printf '%s' "$found" | cut -f1)
        bws secret edit --value "$value" "$secret_id" >/dev/null || die "bws secret edit failed"
        echo "Updated: $env_name"
    else
        project_id=$(bws_project_id)
        if [[ -n "$desc" ]]; then
            bws_key="$env_name - $desc"
        else
            bws_key="$env_name"
        fi
        bws secret create "$bws_key" "$value" "$project_id" >/dev/null || die "bws secret create failed"
        echo "Created: $env_name"
    fi
    cache_clear
}

bws_delete_by_env() {
    local env_name="$1"
    local found secret_id
    found=$(bws_find_secret "$env_name") || die "$env_name not found in BWS"
    secret_id=$(printf '%s' "$found" | cut -f1)
    bws secret delete "$secret_id" >/dev/null || die "bws secret delete failed"
    echo "Deleted: $env_name"
    cache_clear
}

case "${1:-}" in
    cache-clear)
        cache_clear
        echo "Cache cleared."
        ;;
    cache-refresh)
        # Force a synchronous refresh of the cache (used by background jobs)
        load_secrets_from_backend
        cache_write
        echo "Cache refreshed."
        ;;
    cache-path)
        cache_file
        ;;
    keys)
        list_sensitive_keys
        ;;
    keys-meta)
        # Tab-separated: env_name\tbws_key\tnote (BWS backend only)
        load_secrets
        if [[ "$BACKEND" == "bws" && -n "$BWS_META_CACHE" ]]; then
            printf '%s\n' "$BWS_META_CACHE"
        else
            # SOPS fallback: just env_name with no extra metadata
            while IFS= read -r key; do
                [[ -n "$key" ]] && printf '%s\t%s\t\n' "$key" "$key"
            done < <(list_sensitive_keys)
        fi
        ;;
    dotenv)
        load_secrets
        printf '%s\n' "$SECRETS_CACHE"
        ;;
    shell)
        shift
        if [[ "${1:-}" == "--all" ]]; then
            selected_keys=()
            while IFS= read -r key; do
                [[ -n "$key" ]] && selected_keys+=("$key")
            done < <(list_sensitive_keys)
        else
            [[ $# -gt 0 ]] || die "Usage: dotfiles-secrets shell [--all|KEY ...]"
            selected_keys=("$@")
        fi
        print_shell_exports "${selected_keys[@]}"
        ;;
    paths)
        printf 'DOTFILES_SECRETS_BACKEND=%s\n' "$BACKEND"
        printf 'DOTFILES_SECRETS_DIR=%s\n' "$(dotfiles_secrets_dir)"
        if [[ "$BACKEND" == "bws" ]]; then
            printf 'BWS_TOKEN_FILE=%s\n' "$BWS_TOKEN_FILE"
        else
            printf 'SECRETS_ENC=%s\n' "${SECRETS_ENC:-$(dotfiles_secrets_enc)}"
            printf 'SOPS_CONFIG=%s\n' "${SOPS_CONFIG:-$(dotfiles_secrets_sops_config)}"
            printf 'SOPS_AGE_KEY_FILE=%s\n' "$(dotfiles_secrets_age_key)"
        fi
        ;;
    fix-perms)
        dotfiles_secrets_harden_permissions
        ;;
    write-telegram-env)
        shift
        [[ $# -eq 2 ]] || die "Usage: dotfiles-secrets write-telegram-env SECRET_NAME STATE_DIR"
        write_telegram_env "$1" "$2"
        ;;
    set)
        shift
        [[ "$BACKEND" == "bws" ]] || die "'set' requires bws backend (current: $BACKEND). Use secrets-edit for sops."
        set_key="" set_value="" set_desc=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --note|--desc) set_desc="$2"; shift 2 ;;
                *)
                    if [[ -z "$set_key" ]]; then set_key="$1"
                    elif [[ -z "$set_value" ]]; then set_value="$1"
                    else die "Unexpected arg: $1"
                    fi
                    shift ;;
            esac
        done
        [[ -n "$set_key" ]] || die "Usage: dotfiles-secrets set KEY [VALUE] [--note DESC]"
        if [[ -z "$set_value" ]]; then
            printf 'Value for %s: ' "$set_key" >&2
            IFS= read -rs set_value
            echo "" >&2
        fi
        [[ -n "$set_value" ]] || die "Empty value"
        bws_upsert "$set_key" "$set_value" "$set_desc"
        ;;
    rm)
        shift
        [[ "$BACKEND" == "bws" ]] || die "'rm' requires bws backend (current: $BACKEND). Use secrets-edit for sops."
        rm_yes=false
        rm_key=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --yes|-y) rm_yes=true; shift ;;
                *) rm_key="$1"; shift ;;
            esac
        done
        [[ -n "$rm_key" ]] || die "Usage: dotfiles-secrets rm [--yes] KEY"
        if ! $rm_yes; then
            printf 'Delete %s? (y/N) ' "$rm_key" >&2
            read -r rm_confirm
            [[ "$rm_confirm" == [yY]* ]] || { echo "Cancelled."; exit 0; }
        fi
        bws_delete_by_env "$rm_key"
        ;;
    list-full)
        [[ "$BACKEND" == "bws" ]] || die "'list-full' requires bws backend"
        bws_list_full
        ;;
    *)
        cat >&2 <<EOF
Usage:
  dotfiles-secrets keys              List env var names
  dotfiles-secrets keys-meta         List env_name, bws_key, note (tab-separated)
  dotfiles-secrets dotenv            Dump all secrets as dotenv
  dotfiles-secrets shell KEY [...]   Print shell export statements
  dotfiles-secrets shell --all       Export all secrets
  dotfiles-secrets set KEY [VAL] [--note DESC]   Create or update a BWS secret
  dotfiles-secrets rm [--yes] KEY    Delete a BWS secret
  dotfiles-secrets list-full         List BWS secrets with IDs (for tooling)
  dotfiles-secrets paths             Show backend config paths
  dotfiles-secrets fix-perms         Fix file permissions
  dotfiles-secrets write-telegram-env SECRET_NAME STATE_DIR
  dotfiles-secrets cache-clear       Clear local secrets cache
  dotfiles-secrets cache-refresh     Force synchronous cache refresh
  dotfiles-secrets cache-path        Print cache file path

  Backend: $BACKEND (auto: bws if token exists, else sops)
  Cache: ~/.cache/dotfiles-secrets/ (TTL: ${CACHE_TTL}s, override: DOTFILES_SECRETS_CACHE_TTL)
  BWS key convention: "ENV_VAR_NAME - description" → env var is part before " - "
EOF
        exit 1
        ;;
esac
