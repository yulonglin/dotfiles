#!/usr/bin/env bash
# shellcheck shell=bash
# Advisory promotion-readiness check for an obsidian-headless vault currently
# running pull-only sync. Prints a recommendation only — it never changes the
# sync mode. Promote manually with:
#   ob sync-config --path <vault-path> --mode bidirectional
set -uo pipefail

OB_CONFIG_DIR="${OB_CONFIG_DIR:-$HOME/.config/obsidian-headless}"
SYNC_DIR="$OB_CONFIG_DIR/sync"

usage() {
    cat <<'EOF'
Usage: obsidian-sync-check [--path <vault-path>]

Advisory only: reports whether a pull-only obsidian-headless vault looks safe
to promote to bidirectional sync. Never changes the sync mode itself.

Without --path, checks every vault configured under
~/.config/obsidian-headless/sync/.

Exit codes:
  0  safe to promote
  1  not yet safe to promote
  2  usage or missing-tool error
  3  not applicable (no matching vault, or already bidirectional/mirror-remote)
EOF
}

# check_one_vault VAULT_PATH CONFIG_JSON
# Prints a recommendation line for the vault. Returns 0=safe, 1=not-safe, 2=na.
check_one_vault() {
    local vault_path="$1" vault_conf="$2"
    local vault_dir vault_log mode last_line

    vault_dir="$(dirname "$vault_conf")"
    vault_log="$vault_dir/sync.log"

    mode="$(ob sync-status --path "$vault_path" 2>/dev/null | awk -F': ' '/Sync mode:/ {print $2}')"
    if [[ "$mode" != "pull-only" ]]; then
        echo "N/A       $vault_path: mode is '${mode:-unknown}' — check only applies to pull-only vaults"
        return 2
    fi

    if [[ ! -s "$vault_log" ]]; then
        echo "NOT SAFE  $vault_path: no completed sync yet (sync.log missing or empty)"
        return 1
    fi

    # Bounded tail — sync.log grows unboundedly, no need to scan the whole file for the last line.
    last_line="$(tail -n 20 "$vault_log" 2>/dev/null | grep -v '^[[:space:]]*$' | tail -1)"

    if [[ "$last_line" == *"Disconnected from server"* ]]; then
        echo "NOT SAFE  $vault_path: last event was a disconnect — $last_line"
        return 1
    fi

    if [[ "$last_line" == *"Fully synced"* ]]; then
        echo "SAFE      $vault_path: last event was 'Fully synced' — no pending transfers detected"
        return 0
    fi

    echo "NOT SAFE  $vault_path: sync pass appears in progress — last event: $last_line"
    return 1
}

target_path=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --path) target_path="$2"; shift 2 ;;
        -h|--help) usage; exit 0 ;;
        *) echo "Unknown argument: $1" >&2; usage >&2; exit 2 ;;
    esac
done

command -v ob >/dev/null 2>&1 || { echo "obsidian-headless (ob) not installed" >&2; exit 2; }
command -v jq >/dev/null 2>&1 || { echo "jq not installed" >&2; exit 2; }

if [[ ! -d "$SYNC_DIR" ]]; then
    echo "No vaults configured under $SYNC_DIR" >&2
    exit 3
fi

worst=na
any=false

for vault_conf in "$SYNC_DIR"/*/config.json; do
    [[ -f "$vault_conf" ]] || continue

    this_path="$(jq -r '.vaultPath // empty' "$vault_conf" 2>/dev/null)"
    if [[ -n "$target_path" ]] && [[ "$this_path" != "$target_path" ]]; then
        continue
    fi

    any=true

    if [[ -z "$this_path" ]]; then
        echo "SKIP      $vault_conf: no vaultPath in config"
        continue
    fi

    check_one_vault "$this_path" "$vault_conf"
    case "$?" in
        1) worst=not-safe ;;
        0) [[ "$worst" == not-safe ]] || worst=safe ;;
    esac
done

if [[ "$any" != "true" ]]; then
    if [[ -n "$target_path" ]]; then
        echo "No configured vault found at path: $target_path" >&2
    else
        echo "No vaults configured under $SYNC_DIR" >&2
    fi
    exit 3
fi

case "$worst" in
    not-safe) exit 1 ;;
    safe) exit 0 ;;
    *) exit 3 ;;
esac
